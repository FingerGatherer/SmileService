<Window x:Class="SmileService.Views.OrderDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование заказа" Height="640" Width="498" 
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#F5F5F7">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TxtTitle" Text="Заказ #1" FontSize="20" FontWeight="Bold" Foreground="#111111" Margin="0,0,0,15"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,5,0">

                <TextBlock Text="Данные клиента" FontWeight="Bold" Foreground="#1976D2" Margin="0,5,0,5"/>
                <Border Background="White" CornerRadius="5" Padding="12" BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="ФИО Клиента:" FontSize="12" Foreground="#666666" Margin="0,0,0,3"/>
                        <TextBox x:Name="EditClientName" Height="32" VerticalContentAlignment="Center" Margin="0,0,0,10"/>

                        <TextBlock Text="Номер телефона:" FontSize="12" Foreground="#666666" Margin="0,0,0,3"/>
                        <TextBox x:Name="EditClientPhone" Height="32" VerticalContentAlignment="Center"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="Данные устройства" FontWeight="Bold" Foreground="#1976D2" Margin="0,5,0,5"/>
                <Border Background="White" CornerRadius="5" Padding="12" BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Модель устройства:" FontSize="12" Foreground="#666666" Margin="0,0,0,3"/>
                        <TextBox x:Name="EditDeviceModel" Height="32" VerticalContentAlignment="Center" Margin="0,0,0,10"/>

                        <TextBlock Text="Серийный номер:" FontSize="12" Foreground="#666666" Margin="0,0,0,3"/>
                        <TextBox x:Name="EditSerialNumber" Height="32" VerticalContentAlignment="Center" Margin="0,0,0,10"/>

                        <TextBlock Text="Комплектация:" FontSize="12" Foreground="#666666" Margin="0,0,0,3"/>
                        <TextBox x:Name="EditEquipment" Height="32" VerticalContentAlignment="Center" Margin="0,0,0,10"/>

                        <TextBlock Text="Описание неисправности:" FontSize="12" Foreground="#666666" Margin="0,0,0,3"/>
                        <TextBox x:Name="EditDescription" Height="60" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" Padding="5"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="Назначить мастера" FontWeight="Bold" Foreground="#1976D2" Margin="0,5,0,5"/>
                <Border Background="White" CornerRadius="5" Padding="12" BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,0,15">
                    <StackPanel>
                        <ComboBox x:Name="ComboMaster" Height="35" DisplayMemberPath="FullName" SelectedValuePath="Id"/>
                    </StackPanel>
                </Border>

                <Grid Margin="0,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="Текущий статус" FontWeight="Bold" Margin="0,0,0,5"/>
                        <ComboBox x:Name="ComboStatus" Height="35">
                            <ComboBoxItem Content="Принят" Background="#E3F2FD" FontWeight="Bold"/>
                            <ComboBoxItem Content="В работе" Background="#FFF3E0" FontWeight="Bold"/>
                            <ComboBoxItem Content="Выдан" Background="#E8F5E9" FontWeight="Bold"/>
                            <ComboBoxItem Content="Архив" Background="#F5F5F5" FontWeight="Bold"/>
                        </ComboBox>

                        <TextBlock x:Name="TxtFinishedDate" FontSize="11" Foreground="#2E7D32" FontWeight="SemiBold" Margin="2,5,0,0" Visibility="Visible"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <TextBlock Text="Стоимость ремонта (₽)" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="TxtPrice" Height="35" VerticalContentAlignment="Center" Padding="5,0"/>
                    </StackPanel>
                </Grid>

            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Отмена" Width="100" Height="35" Background="Transparent" Foreground="#555555" BorderBrush="#777777" Click="BtnCancel_Click" Margin="0,0,10,0"/>
            <Button Content="Сохранить" Width="120" Height="35" Background="#1976D2" Foreground="White" Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>