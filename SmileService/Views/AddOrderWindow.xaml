<Window x:Class="SmileService.Views.AddOrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Новый заказ" Height="570" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Регистрация нового заказа" FontSize="18" FontWeight="Bold" Margin="0,0,0,15" Foreground="#1976D2" HorizontalAlignment="Center"/>

        <StackPanel Grid.Row="1" VerticalAlignment="Top">
            <TextBox x:Name="TxtClientName" Margin="0,8"
                     materialDesign:HintAssist.Hint="ФИО Клиента"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}" />

            <TextBox x:Name="TxtClientPhone" Margin="0,8"
                     materialDesign:HintAssist.Hint="Номер телефона клиента"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}" />

            <TextBox x:Name="TxtDeviceModel" Margin="0,8"
                     materialDesign:HintAssist.Hint="Модель устройства"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}" />

            <TextBox x:Name="TxtDefect" Margin="0,8" Height="80" 
                     TextWrapping="Wrap" AcceptsReturn="True"
                     materialDesign:HintAssist.Hint="Описание неисправности"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}" />

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="PriceBox" Margin="0,8,8,8"
                         materialDesign:HintAssist.Hint="Предварительная цена (₽)"
                         Text="0"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" />

                <ComboBox Grid.Column="1" x:Name="ComboMaster" Margin="8,8,0,8"
                          materialDesign:HintAssist.Hint="Назначить мастера"
                          DisplayMemberPath="FullName"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}" />
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Отмена" IsCancel="True" Style="{StaticResource MaterialDesignFlatButton}" Margin="0,0,10,0" Foreground="#555555"/>
            <Button x:Name="SaveButton" Content="Сохранить" Click="BtnSave_Click" Style="{StaticResource MaterialDesignRaisedButton}" Background="#1976D2" BorderBrush="#777777" Width="110"/>
        </StackPanel>
    </Grid>
</Window>