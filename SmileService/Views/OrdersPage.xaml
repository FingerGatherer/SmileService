<Page x:Class="SmileService.Views.OrdersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="930"
      Title="OrdersPage"
      Loaded="Page_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="25,20,25,10">
            <TextBlock Text="Управление заявками" FontSize="22" FontWeight="Bold" Foreground="#222222" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="25,5,25,15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button x:Name="BtnAdd"  Style="{StaticResource MaterialDesignRaisedButton}" 
                        Content="+ Новая заявка" Click="BtnAdd_Click"
                        Background="#1976D2" BorderBrush="#1976D2" 
                        Height="40" materialDesign:ButtonAssist.CornerRadius="6" FontWeight="Bold"/>

                <ComboBox x:Name="StatusFilterComboBox" Width="150" Margin="15,0,0,0" Height="56"
                          materialDesign:HintAssist.Hint="Статус:" SelectionChanged="FilterChanged"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}">
                    <ComboBoxItem Content="Все"/>
                    <ComboBoxItem Content="Новая"/>
                    <ComboBoxItem Content="В работе"/>
                    <ComboBoxItem Content="Выдан"/>
                    <ComboBoxItem Content="Архив"/>
                </ComboBox>

                <ComboBox x:Name="MasterFilterComboBox" Width="150" Margin="10,0,0,0" Height="56"
                          materialDesign:HintAssist.Hint="Все мастера" DisplayMemberPath="FullName"
                          SelectionChanged="FilterChanged" Style="{StaticResource MaterialDesignOutlinedComboBox}"/>

                <Button Style="{StaticResource MaterialDesignOutlinedButton}" 
                        Content="Сбросить" Click="ResetFilter_Click"
                        BorderBrush="#E5E8ED" Foreground="#555555"
                        Height="40" Margin="10,0,0,0" materialDesign:ButtonAssist.CornerRadius="6"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2" Background="White" CornerRadius="8" Margin="25,0,25,10" BorderBrush="#E5E8ED" BorderThickness="1">
            <DataGrid x:Name="OrdersGrid" AutoGenerateColumns="False" IsReadOnly="True" 
                      Background="Transparent" RowHeight="50" GridLinesVisibility="Horizontal" 
                      HorizontalGridLinesBrush="#F4F6F9" BorderThickness="0" HeadersVisibility="Column"
                      MouseDoubleClick="OrdersGrid_MouseDoubleClick">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F8F9FA"/>
                        <Setter Property="Foreground" Value="#666666"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="15,10"/>
                        <Setter Property="BorderBrush" Value="#E5E8ED"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="15,0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#FFF0F2F5"/>
                                <Setter Property="Foreground" Value="#1976D2"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70"/>

                    <DataGridTextColumn Header="Клиент" Binding="{Binding Device.Client.FullName}" Width="180" FontWeight="SemiBold"/>

                    <DataGridTextColumn Header="Телефон" Binding="{Binding Device.Client.Phone}" Width="120"/>

                    <DataGridTextColumn Header="Устройство" Binding="{Binding Device.Model}" Width="180"/>

                    <DataGridTemplateColumn Header="Статус" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border x:Name="StatusBorder" CornerRadius="4" Padding="8,4" HorizontalAlignment="Center" Background="#ECEFF1">
                                    <TextBlock x:Name="StatusText" Text="{Binding Status}" FontWeight="SemiBold" Foreground="#37474F" FontSize="12"/>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Status}" Value="Новая">
                                        <Setter TargetName="StatusBorder" Property="Background" Value="#816BFF"/>
                                        <Setter TargetName="StatusText" Property="Foreground" Value="#000000"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="В работе">
                                        <Setter TargetName="StatusBorder" Property="Background" Value="#DCEB00"/>
                                        <Setter TargetName="StatusText" Property="Foreground" Value="#000000"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="Выдан">
                                        <Setter TargetName="StatusBorder" Property="Background" Value="#85FF29"/>
                                        <Setter TargetName="StatusText" Property="Foreground" Value="#000000"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="Архив">
                                        <Setter TargetName="StatusBorder" Property="Background" Value="#F5F5F5"/>
                                        <Setter TargetName="StatusText" Property="Foreground" Value="#777777"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Принято" Binding="{Binding CreatedDate, StringFormat=\{0:dd.MM.yyyy\}}" Width="130"/>
                    <DataGridTextColumn Header="Стоимость" Binding="{Binding TotalPrice, StringFormat=\{0:N0\} ₽}" Width="130" FontWeight="SemiBold"/>
                    <DataGridTextColumn Header="Мастер" Binding="{Binding Master.FullName}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Grid Grid.Row="3" Margin="25,0">
            <TextBlock x:Name="TxtPageInfo" Text="Показаны 1–7 из 20 заявок" VerticalAlignment="Center" Foreground="#777777" HorizontalAlignment="Left"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button x:Name="BtnPrev" Style="{StaticResource MaterialDesignFlatButton}" Content="&lt;" Padding="5" Margin="2" Click="BtnPrevPage_Click"/>

                <Button x:Name="BtnPage1" Style="{StaticResource MaterialDesignFlatMidBgButton}" Content="1" Background="#1976D2" Foreground="White" Width="32" Height="32" Padding="0" Margin="2" Click="BtnPageNum_Click"/>
                <Button x:Name="BtnPage2" Style="{StaticResource MaterialDesignFlatButton}" Content="2" Width="32" Height="32" Padding="0" Margin="2" Click="BtnPageNum_Click"/>
                <Button x:Name="BtnPage3" Style="{StaticResource MaterialDesignFlatButton}" Content="3" Width="32" Height="32" Padding="0" Margin="2" Click="BtnPageNum_Click"/>

                <Button x:Name="BtnNext" Style="{StaticResource MaterialDesignFlatButton}" Content="&gt;" Padding="5" Margin="2" Click="BtnNextPage_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>