<Page x:Class="SmileService.Views.ClientsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Управление клиентами" Background="White">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="База клиентов ООО «Смайл»" FontSize="20" FontWeight="Bold" Foreground="#1976D2" VerticalAlignment="Center" Margin="0,0,30,0"/>
            <TextBox x:Name="TxtClientSearch" Width="250" Height="30" VerticalContentAlignment="Center" Padding="5,0" 
                     Text="Поиск по ФИО или телефону..." Foreground="Gray" GotFocus="TxtClientSearch_GotFocus"/>
        </StackPanel>

        <DataGrid x:Name="ClientsGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" 
          Background="White" RowHeight="45" GridLinesVisibility="Horizontal" BorderThickness="0"
          HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="ФИО Клиента" Binding="{Binding FullName}" Width="2*" FontWeight="SemiBold"/>
                <DataGridTextColumn Header="Номер телефона" Binding="{Binding Phone}" Width="1.5*"/>
                <DataGridTextColumn Header="Последнее обращение" Binding="{Binding LastOrderDate, StringFormat=\{0:dd.MM.yyyy\}}" Width="1.5*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>